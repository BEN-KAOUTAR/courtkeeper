<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/image1">

    <!-- Dark gradient overlay top to bottom -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#99000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ── Responsive Guidelines (5% margins) ── -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.05" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.95" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.04" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.97" />

    <!-- ── App Logo / Title ── -->
    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="🎾 CourtKeeper"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.04"
        app:layout_constraintStart_toStartOf="@id/guideLeft"
        app:layout_constraintTop_toTopOf="@id/guideTop"
        app:layout_constraintEnd_toStartOf="@id/btnHistory"
        app:layout_constraintBottom_toBottomOf="@id/btnHistory" />

    <!-- ── History Button ── -->
    <Button
        android:id="@+id/btnHistory"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:background="@drawable/bg_btn_history"
        android:paddingHorizontal="18dp"
        android:text="📋 HISTORY"
        android:textColor="#00C9FF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        app:backgroundTint="@null"
        app:layout_constraintEnd_toEndOf="@id/guideRight"
        app:layout_constraintTop_toTopOf="@id/guideTop" />

    <!-- ══════════════════════════════════════
         WINNER CONTAINER (hidden by default)
         ══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/winnerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_glass"
        android:elevation="16dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingVertical="48dp"
        android:paddingHorizontal="32dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btnReset"
        app:layout_constraintEnd_toEndOf="@id/guideRight"
        app:layout_constraintStart_toStartOf="@id/guideLeft"
        app:layout_constraintTop_toBottomOf="@id/btnHistory"
        app:layout_constraintVertical_bias="0.4">

        <TextView
            android:id="@+id/tvWinnerMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Joueur 1 Gagne!"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="🏆"
            android:textSize="72sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Champion du Match!"
            android:textColor="#00C9FF"
            android:textSize="16sp"
            android:textStyle="italic"
            android:letterSpacing="0.03" />
    </LinearLayout>

    <!-- ══════════════════════════════════════
         PLAYER CARDS
         ══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/cardsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/buttonsContainer"
        app:layout_constraintEnd_toEndOf="@id/guideRight"
        app:layout_constraintStart_toStartOf="@id/guideLeft"
        app:layout_constraintTop_toBottomOf="@id/btnHistory"
        app:layout_constraintVertical_bias="0.38">

        <!-- ── Score column legend ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="6dp"
            android:paddingBottom="6dp">

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <TextView
                android:layout_width="52dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="SETS"
                android:textColor="#D72E2E"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="52dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="JEUX"
                android:textColor="#00BCD4"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="PTS"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- ── Player 1 Card ── -->
        <LinearLayout
            android:id="@+id/topPlayerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_glass"
            android:elevation="8dp"
            android:gravity="center_vertical"
            android:minHeight="100dp"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="22dp">

            <!-- Name block -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPlayer1Name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Joueur 1"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="✏️ Modifier le nom"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Sets -->
            <TextView
                android:id="@+id/tvPlayer1Sets"
                android:layout_width="52dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="0"
                android:textColor="#D72E2E"
                android:textSize="30sp"
                android:textStyle="bold" />

            <!-- Games -->
            <TextView
                android:id="@+id/tvPlayer1Games"
                android:layout_width="52dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="0"
                android:textColor="#00BCD4"
                android:textSize="32sp"
                android:textStyle="bold" />

            <!-- Points -->
            <TextView
                android:id="@+id/tvPlayer1Score"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="44sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── VS Divider ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#2AFFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:text="VS"
                android:textColor="#44FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#2AFFFFFF" />
        </LinearLayout>

        <!-- ── Player 2 Card ── -->
        <LinearLayout
            android:id="@+id/bottomPlayerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_glass"
            android:elevation="8dp"
            android:gravity="center_vertical"
            android:minHeight="100dp"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="22dp">

            <!-- Name block -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPlayer2Name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Joueur 2"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="✏️ Modifier le nom"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Sets -->
            <TextView
                android:id="@+id/tvPlayer2Sets"
                android:layout_width="52dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="0"
                android:textColor="#D72E2E"
                android:textSize="30sp"
                android:textStyle="bold" />

            <!-- Games -->
            <TextView
                android:id="@+id/tvPlayer2Games"
                android:layout_width="52dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="0"
                android:textColor="#00BCD4"
                android:textSize="32sp"
                android:textStyle="bold" />

            <!-- Points -->
            <TextView
                android:id="@+id/tvPlayer2Score"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="44sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════
         SCORE BUTTONS
         ══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/buttonsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp"
        app:layout_constraintBottom_toTopOf="@id/btnReset"
        app:layout_constraintEnd_toEndOf="@id/guideRight"
        app:layout_constraintStart_toStartOf="@id/guideLeft">

        <Button
            android:id="@+id/btnPlayer1Point"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_btn_score"
            android:elevation="6dp"
            android:text="JOUEUR 1\nMARQUE"
            android:textColor="#0A0A0A"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnPlayer2Point"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_btn_score"
            android:elevation="6dp"
            android:text="JOUEUR 2\nMARQUE"
            android:textColor="#0A0A0A"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            app:backgroundTint="@null" />
    </LinearLayout>

    <!-- ══════════════════════════════════════
         RESET BUTTON
         ══════════════════════════════════════ -->
    <Button
        android:id="@+id/btnReset"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:background="@drawable/bg_btn_reset"
        android:elevation="4dp"
        android:text="🔄  RESET MATCH"
        android:textColor="#DDDDDD"
        android:textSize="15sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        app:backgroundTint="@null"
        app:layout_constraintBottom_toBottomOf="@id/guideBottom"
        app:layout_constraintEnd_toEndOf="@id/guideRight"
        app:layout_constraintStart_toStartOf="@id/guideLeft" />

</androidx.constraintlayout.widget.ConstraintLayout>
